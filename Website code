<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <title>My mini motivation hub</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        background: linear-gradient(to bottom right, #0f2027, #203a43, #2c5364);
        color: #ffffff;
        margin: 0;
        padding: 0;
        text-align: center;
      }
      .container {
        max-width: 800px;
        margin: 40px auto;
        background: rgba(0, 0, 0, 0.3);
        padding: 20px;
        border-radius: 12px;
      }
      h1 {
        color: #ffd166;
      }
      h2 {
        color: #06d690;
      }
      .quote, .fact {
        margin: 15px 0;
        padding: 10px;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.08);
      }
      button {
        margin-top: 20px;
        padding: 10px 18px;
        border-radius: 20px;
        border: none;
        background: #ffd166;
        color: #000;
        font-weight: bold;
      }
      footer {
        margin-top: 20px;
        font-size: 12px;
        color: #cccccc;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>Welcome to my mini motivation hub</h1>
      <p>Created by David iheomachiluru using GitHub codespace and AI help</p>
      
      <h2>Quote of the Day</h2>
      <div class="quote">
        "Small daily action can create a big future."
      </div>
      
      <h2>Fun Fact</h2>
      <div class="fact">
        Water can exist as solid, liquid and gas at the same time at a point called the triple point
      </div>
      
      <button onclick="alert('You\'ve got this! One small step today!')">
        Tap for a quick boost
      </button>
      
      <footer>
        This page is my experiment with generative AI + coding. I wrote and customized the content myself.
      </footer>
    </div>

    <script>
      // Simple customization - change background color at night
      const hour = new Date().getHours();
      if (hour >= 18 || hour < 6) {
        document.body.style.background = "linear-gradient(to bottom right, #000428, #004e92)";
      }
    </script>
  </body>
</html>
